{
  "name": "islem",
  "version": "1.0.0",
  "main": "index.js",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.110.8",
    "expo": "~57.0.8",
    "expo-asset": "~57.0.7",
    "expo-audio": "~57.0.3",
    "expo-build-properties": "~57.0.7",
    "expo-localization": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-url-polyfill": "^4.0.0",
    "react-native-webview": "16.0.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "xcode": "xed ios/lem.xcworkspace",
    "xcode:metro": "expo start --clear",
    "check": "npx expo-doctor",
    "check:cloud": "node scripts/verify-cloud-security.mjs",
    "check:ios": "expo export --platform ios --output-dir /private/tmp/islem-ios-export-check --no-bytecode --max-workers 1 --clear",
    "eas:login": "npx eas-cli login",
    "build:ios": "npx eas-cli build --platform ios --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --profile production"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-webview"
      ]
    }
  },
  "private": true,
  "devDependencies": {
    "@types/react": "~19.2.4",
    "typescript": "~6.0.3"
  }
}
